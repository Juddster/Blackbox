                     BuildableName = "BlackboxWatch.app"
                     BlueprintName = "BlackboxWatch"
                     ReferencedContainer = "container:Blackbox.xcodeproj">
                  </BuildableReference>
               </EnvironmentBuildable>
            </ActionContent>
         </ExecutionAction>
